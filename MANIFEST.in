# Include documentation and metadata
include README.md
include LICENSE
include requirements.txt

# Include source directory
recursive-include src *.py *.txt

# Exclude unnecessary files
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.so
global-exclude .DS_Store
global-exclude .git*
global-exclude *.swp
global-exclude *.swo

# Exclude build and test artifacts
prune build
prune dist
prune .pytest_cache
prune .tox
prune *.egg-info

# Exclude non-package directories
prune .claude
prune ui
prune tests
prune docs
prune demos
prune Data
exclude CLAUDE.md
exclude nul
